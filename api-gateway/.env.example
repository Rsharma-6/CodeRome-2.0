# Server configuration
PORT=3000                  # Port your app runs on

# Redis configuration
REDIS_HOST=localhost       # Redis host
REDIS_PORT=6379            # Redis port
REDIS_PASSWORD=yourpassword  # Redis password (if any)

# External services
STORAGE_SERVICE_URL=http://localhost:5000   # URL of storage service
COMPILER_SERVICE_URL=http://localhost:6000  # URL of compiler service

# JWT secrets
JWT_ACCESS_SECRET=your_access_secret       # Secret for access tokens
JWT_REFRESH_SECRET=your_refresh_secret     # Secret for refresh tokens

# Frontend
CLIENT_URL=http://localhost:3001           # URL of your frontend app

# Environment
NODE_ENV=development                        # development | production